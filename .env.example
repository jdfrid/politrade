# Wallet (never commit real values)
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=0

# Optional overrides (defaults in config/settings.yaml)
MAX_POSITION_USD=50
TAKE_PROFIT_MULTIPLIER=2.0

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database path (default: ./data/politrade.db; on Render: sqlite:////var/data/politrade.db)
DATABASE_URL=sqlite:///./data/politrade.db

# Render: watch | trade
POLITRADE_MODE=trade

# Set to 1 to halt trading (also works on Render without a file)
# KILL_SWITCH=0
